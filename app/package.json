{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run test && npm run typecheck",
    "check:sandbox": "./scripts/check-sandbox.sh",
    "test:ui": "jest",
    "test:ui:watch": "jest --watch",
    "e2e:build:ios": "detox build -c ios.sim.debug",
    "e2e:test:ios": "detox test -c ios.sim.debug",
    "e2e:test:ios:small": "detox test -c ios.sim.small"
  },
  "engines": {
    "node": ">=20.19.4 <23"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~55.0.5",
    "expo-notifications": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "detox": "^20.47.0",
    "install": "^0.13.0",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  },
  "private": true
}
